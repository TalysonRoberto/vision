# --- Banco de dados (Supabase — project_id: svdxrekqtbtzifkreqio) ---
# Em dev local e producao (Vercel) usamos o pooler Supavisor para evitar
# exaustao de conexoes no Serverless.
#   DATABASE_URL -> aws-1-us-west-2.pooler.supabase.com:6543 (transaction / pgbouncer)
#   DIRECT_URL   -> aws-1-us-west-2.pooler.supabase.com:5432 (session / migrations)
#
# Usuario do pooler: "postgres.[project-ref]" (com sufixo).
# Se a senha tiver caracteres especiais, URL-encode:
#   @ -> %40   * -> %2A   # -> %23   / -> %2F
DATABASE_URL="postgresql://postgres.svdxrekqtbtzifkreqio:SUA_SENHA@aws-1-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.svdxrekqtbtzifkreqio:SUA_SENHA@aws-1-us-west-2.pooler.supabase.com:5432/postgres"

# --- NextAuth.js (Auth.js v5) ---
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="gere-um-secret-aleatorio"
NEXTAUTH_URL="http://localhost:3000"

# --- Google OAuth (opcional) ---
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""

# --- Supabase Storage (upload de midia) ---
NEXT_PUBLIC_SUPABASE_URL="https://svdxrekqtbtzifkreqio.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sua-anon-key"
SUPABASE_SERVICE_ROLE_KEY="sua-service-role-key"
