# --- Banco de dados (Supabase — project_id: svdxrekqtbtzifkreqio) ---
# Em dev local usamos a conexao direta (db.[ref].supabase.co:5432) para
# runtime E migrations. Em producao (Vercel), troque DATABASE_URL pelo pooler
# Supavisor (aws-0-[regiao].pooler.supabase.com:6543?pg_bouncer=true) para
# evitar exaustao de conexoes no Serverless. Mantenha DIRECT_URL na conexao
# direta (o pooler com pgbouncer nao suporta migrations).
#
# Usuario da conexao direta: "postgres" (sem sufixo do project-ref).
# Usuario do pooler: "postgres.[project-ref]" (com sufixo).
#
# Se a senha tiver caracteres especiais, URL-encode:
#   @ -> %40   * -> %2A   # -> %23   / -> %2F
DATABASE_URL="postgresql://postgres:SUA_SENHA@db.svdxrekqtbtzifkreqio.supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:SUA_SENHA@db.svdxrekqtbtzifkreqio.supabase.co:5432/postgres"

# --- NextAuth.js (Auth.js v5) ---
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="gere-um-secret-aleatorio"
NEXTAUTH_URL="http://localhost:3000"

# --- Google OAuth (opcional) ---
# AUTH_GOOGLE_ID=""
# AUTH_GOOGLE_SECRET=""

# --- Cloudinary (upload de mídia — Fase 2) ---
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
